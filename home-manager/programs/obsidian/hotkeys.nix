{
  "workspace:close" = [
    {
      "modifiers" = [ "Alt" ];
      "key" = "X";
    }
  ];

  "file-explorer:open" = [
    {
      "modifiers" = [ "Alt" ];
      "key" = "e";
    }
  ];

  "workspace:next-tab" = [
    {
      "modifiers" = [ "Ctrl" ];
      "key" = "Tab";
    }
    {
      "modifiers" = [ "Ctrl" ];
      "key" = "PageDown";
    }
    {
      "modifiers" = [ "Alt" ];
      "key" = ".";
    }
  ];
  "workspace:previous-tab" = [
    {
      "modifiers" = [
        "Ctrl"
        "Shift"
      ];
      "key" = "Tab";
    }
    {
      "modifiers" = [ "Ctrl" ];
      "key" = "PageUp";
    }
    {
      "modifiers" = [ "Alt" ];
      "key" = ",";
    }
  ];
  "switcher:open" = [ ];
  "darlal-switcher-plus:switcher-plus:open" = [
    {
      "modifiers" = [ "Mod" ];
      "key" = " ";
    }
  ];
